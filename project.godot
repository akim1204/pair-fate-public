; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pair Fate"
run/main_scene="res://root.tscn"
config/features=PackedStringArray("4.2", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ItemBag="*res://Global/ItemBag.cs"
PlayerBag="*res://Global/PlayerBag.cs"
NetworkManager="*res://Networking/NetworkManager.cs"
GameManager="*res://Global/GameManager.cs"
MusicManager="*res://Global/MusicManager.tscn"
SoundManager="*res://Global/SoundManager.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=2304
window/size/window_height_override=1296
window/stretch/mode="viewport"
mouse_cursor/custom_image="res://Tilemaps/Assets/Decor/cursor.png"
mouse_cursor/custom_image_hotspot=Vector2(3, 0)
mouse_cursor/tooltip_position_offset=Vector2(0, 0)

[dotnet]

project/assembly_name="Pair Fate"

